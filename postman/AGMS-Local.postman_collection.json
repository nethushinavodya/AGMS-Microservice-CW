{
  "info": {
    "name": "AGMS - Local",
    "_postman_id": "agms-local-collection",
    "description": "Postman collection for AGMS microservices (local). Uses environment variables for host and ports.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Zone-Service",
      "item": [
        {
          "name": "Health - Zone actuator",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{zoneBaseUrl}}/actuator/health",
              "host": [
                "{{host}}"
              ],
              "port": "{{port_zone}}",
              "path": [
                "actuator","health"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Zone",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{zoneCreateBody}}"
            },
            "url": {
              "raw": "{{zoneBaseUrl}}{{zonesPath}}",
              "host": [
                "{{host}}"
              ],
              "path": [
                "api","zones"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 201', function () {\n  pm.expect(pm.response.code).to.be.oneOf([200,201]);\n});",
                  "if (pm.response.code === 200 || pm.response.code === 201) {\n  var json = pm.response.json();\n  if (json.id) {\n    pm.collectionVariables.set('zoneId', json.id);\n  }\n}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Zone by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{zoneBaseUrl}}{{zonesPath}}/{{zoneId}}",
              "host": [
                "{{host}}"
              ],
              "path": [
                "api","zones","{{zoneId}}"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {\n  pm.response.to.have.status(200);\n});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Zone",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{zoneUpdateBody}}"
            },
            "url": {
              "raw": "{{zoneBaseUrl}}{{zonesPath}}/{{zoneId}}",
              "host": [
                "{{host}}"
              ],
              "path": [
                "api","zones","{{zoneId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Zone",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{zoneBaseUrl}}{{zonesPath}}/{{zoneId}}",
              "host": [
                "{{host}}"
              ],
              "path": [
                "api","zones","{{zoneId}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Crop-Service",
      "item": [
        {
          "name": "Create Crop",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{{cropCreateBody}}" },
            "url": { "raw": "{{cropBaseUrl}}{{cropsPath}}", "host": [ "{{host}}" ], "path": [ "api","crops" ] }
          },
          "event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 200 or 201', function () { pm.expect(pm.response.code).to.be.oneOf([200,201]); });", "if (pm.response.code === 200 || pm.response.code === 201) { var json = pm.response.json(); if (json.id) { pm.collectionVariables.set('cropId', json.id); } }" ], "type": "text/javascript" } } ],
          "response": []
        },
        {
          "name": "Update Crop Status",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{{cropStatusBody}}" },
            "url": { "raw": "{{cropBaseUrl}}{{cropsPath}}/{{cropId}}/status", "host": [ "{{host}}" ], "path": [ "api","crops","{{cropId}}","status" ] }
          },
          "response": []
        },
        {
          "name": "Get All Crops",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{cropBaseUrl}}{{cropsPath}}", "host": [ "{{host}}" ], "path": [ "api","crops" ] } },
          "response": []
        }
      ]
    },
    {
      "name": "Automation-Service",
      "item": [
        {
          "name": "Process Sensor Data",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{{automationProcessBody}}" },
            "url": { "raw": "{{automationBaseUrl}}{{automationProcessPath}}", "host": [ "{{host}}" ], "path": [ "api","automation","process" ] }
          },
          "response": []
        },
        {
          "name": "Get Automation Logs",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{automationBaseUrl}}{{automationLogsPath}}", "host": [ "{{host}}" ], "path": [ "api","automation","logs" ] } },
          "response": []
        }
      ]
    },
    {
      "name": "Sensor-Service",
      "item": [
        {
          "name": "Get Latest Telemetry",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{sensorBaseUrl}}{{sensorLatestPath}}", "host": [ "{{host}}" ], "path": [ "api","sensors","latest" ] } },
          "response": []
        }
      ]
    },
    {
      "name": "Eureka-Server",
      "item": [
        {
          "name": "Eureka Dashboard (health)",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{eurekaBaseUrl}}/", "host": [ "http://{{host}}" ], "port": "{{port_eureka}}", "path": [] } },
          "response": []
        }
      ]
    },
    {
      "name": "Api-Gateway",
      "item": [
        {
          "name": "Gateway - Get Zone by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayBaseUrl}}{{zonesPath}}/{{zoneId}}",
              "host": [
                "{{host}}"
              ],
              "port": "{{port_gateway}}",
              "path": [
                "api","zones","{{zoneId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Gateway - Latest Telemetry",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayBaseUrl}}{{sensorLatestPath}}",
              "host": [
                "{{host}}"
              ],
              "port": "{{port_gateway}}",
              "path": [
                "api","sensors","latest"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Gateway - Automation Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayBaseUrl}}{{automationLogsPath}}",
              "host": [
                "{{host}}"
              ],
              "port": "{{port_gateway}}",
              "path": [
                "api","automation","logs"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Gateway - Get All Crops",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayBaseUrl}}{{cropsPath}}",
              "host": [
                "{{host}}"
              ],
              "port": "{{port_gateway}}",
              "path": [
                "api","crops"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "event": [],
  "variable": [
    { "key": "host", "value": "localhost" },

    { "key": "port_zone", "value": "8081" },
    { "key": "port_crop", "value": "8084" },
    { "key": "port_sensor", "value": "8083" },
    { "key": "port_gateway", "value": "8082" },
    { "key": "port_automation", "value": "8085" },
    { "key": "port_eureka", "value": "8761" },
    { "key": "port_config", "value": "8888" },

    { "key": "gatewayBaseUrl", "value": "http://{{host}}:{{port_gateway}}" },
    { "key": "zoneBaseUrl", "value": "http://{{host}}:{{port_zone}}" },
    { "key": "cropBaseUrl", "value": "http://{{host}}:{{port_crop}}" },
    { "key": "sensorBaseUrl", "value": "http://{{host}}:{{port_sensor}}" },
    { "key": "automationBaseUrl", "value": "http://{{host}}:{{port_automation}}" },
    { "key": "eurekaBaseUrl", "value": "http://{{host}}:{{port_eureka}}" },
    { "key": "configBaseUrl", "value": "http://{{host}}:{{port_config}}" },

    { "key": "baseUrl", "value": "{{gatewayBaseUrl}}" },

    { "key": "zonesPath", "value": "/api/zones" },
    { "key": "cropsPath", "value": "/api/crops" },
    { "key": "automationProcessPath", "value": "/api/automation/process" },
    { "key": "automationLogsPath", "value": "/api/automation/logs" },
    { "key": "sensorLatestPath", "value": "/api/sensors/latest" },

    { "key": "zoneId", "value": "1" },
    { "key": "cropId", "value": "1" },

    { "key": "zoneCreateBody", "value": "{\n  \"zoneName\": \"Greenhouse A\",\n  \"minTemp\": 18.5,\n  \"maxTemp\": 28.0\n}" },
    { "key": "zoneUpdateBody", "value": "{\n  \"zoneName\": \"Greenhouse A - Updated\",\n  \"minTemp\": 19.0,\n  \"maxTemp\": 27.5\n}" },
    { "key": "cropCreateBody", "value": "{\n  \"cropName\": \"Lettuce\",\n  \"batchNumber\": \"BATCH-001\",\n  \"zoneId\": \"{{zoneId}}\",\n  \"quantity\": 100\n}" },
    { "key": "cropStatusBody", "value": "{\n  \"status\": \"VEGETATIVE\"\n}" },
    { "key": "automationProcessBody", "value": "{\n  \"deviceId\": \"dev-123\",\n  \"zoneId\": \"{{zoneId}}\",\n  \"temperature\": 26.3,\n  \"humidity\": 55.2,\n  \"capturedAt\": \"2026-04-09T12:00:00Z\"\n}" }
  ]
}
